# 公众号草稿模式配置
# 把这个文件复制成 .env，然后填入真实值

WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_THUMB_MEDIA_ID=

# 0 = 真实提交到公众号草稿箱
# 1 = 只做 dry-run，不调用微信接口
WECHAT_DRY_RUN=0

# ARK 成稿配置
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_TIMEOUT_SECONDS=90

# GitHub API Token（可选，提高 rate limit：60 → 5000 req/hr）
# 支持 Personal Access Token (PAT)，无需额外权限
GITHUB_TOKEN=
